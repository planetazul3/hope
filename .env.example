# Deriv API Connection
DERIV_ENVIRONMENT=DEMO
DERIV_DEMO_TOKEN=your_demo_token_here
DERIV_REAL_TOKEN=your_real_token_here
DERIV_WS_ENDPOINT=wss://ws.derivws.com/websockets/v3
DERIV_APP_ID=1089

# Trading Parameters
DERIV_SYMBOL=R_100
DERIV_CONTRACT_TYPE=CALL
DERIV_CURRENCY=USD
DERIV_STAKE=1.0
DERIV_DURATION_TICKS=5
DERIV_TRADING_ENABLED=false

# Strategy & Inference Parameters (GatedTCN V4)
MODEL_TYPE=TRANSFORMER
TRANSFORMER_MODEL_PATH=model_quantized.onnx
TRANSFORMER_SEQUENCE_LENGTH=32
DERIV_THRESHOLD=0.55

# Advanced Strategy Filters
STRATEGY_MIN_TREND_LENGTH=5
STRATEGY_VOLATILITY_PENALTY=0.05
STRATEGY_MOMENTUM_REWARD=0.02
STRATEGY_MIN_RETURN_RATIO=0.1

# Engine Performance & Safety Limits
DERIV_RECONNECT_BACKOFF_MS=1000
DERIV_MIN_API_INTERVAL_MS=250
DERIV_COOLDOWN_TICKS=16
DERIV_MAX_TICK_LATENCY_MS=10
DERIV_INBOUND_QUEUE_CAPACITY=1024
DERIV_OUTBOUND_QUEUE_CAPACITY=128

# Observability
TICK_AUDIT_LOG_PATH=tick_audit.log
